global:
  scrape_interval: 15s

scrape_configs:
  - job_name: prometheus
    static_configs:
      - targets:
          - "prometheus:9090"
  - job_name: app
    static_configs:
      - targets:
{% for host in groups['app'] %}
        - "{{ hostvars[host].ansible_host }}:80"
{% endfor %}

  - job_name: node_exporter_app
    static_configs:
      - targets:
{% for host in groups['app'] %}
        - "{{ hostvars[host].ansible_host }}:9100"
{% endfor %}